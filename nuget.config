<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <!-- TechIdiots-LLC GitHub Packages feed — hosts dev prereleases of MapLibreNative.Maui.Handlers
         and MaplibreNative.Routing that are not yet published on NuGet.org.
         CI authenticates via GITHUB_TOKEN; local dev requires a PAT with read:packages scope
         stored via: dotnet nuget update source techidiots-github --username <user> --password <PAT> -->
    <add key="techidiots-github" value="https://nuget.pkg.github.com/TechIdiots-LLC/index.json" />
  </packageSources>
</configuration>
