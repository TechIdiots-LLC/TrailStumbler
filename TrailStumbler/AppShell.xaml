<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:TrailStumbler.Views"
       x:Class="TrailStumbler.AppShell"
       Shell.FlyoutBehavior="Disabled"
       Title="TrailStumbler">

    <TabBar>
        <ShellContent Title="Layers"
                      ContentTemplate="{DataTemplate views:LayersPage}"
                      Route="LayersPage" />
        <ShellContent Title="Map"
                      ContentTemplate="{DataTemplate views:MapPage}"
                      Route="MapPage" />
        <ShellContent Title="Settings"
                      ContentTemplate="{DataTemplate views:SettingsPage}"
                      Route="SettingsPage" />
    </TabBar>

</Shell>
